{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skrodzkai.github.io/agentic-peopleos/schemas/evidence-authorization.schema.json",
  "title": "Agentic PeopleOS Evidence Authorization Envelope",
  "description": "The exact evidence-bundle authorization copied unchanged through recommendation, approval, and action events.",
  "type": "object",
  "additionalProperties": false,
  "required": ["bundle_id", "bundle_hash", "artifacts", "material_claim_ids_hash"],
  "properties": {
    "bundle_id": {"$ref": "#/$defs/id"},
    "bundle_hash": {"$ref": "#/$defs/hash"},
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/artifact"}
    },
    "material_claim_ids_hash": {"$ref": "#/$defs/hash"}
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^(?![\\s\\S]*[\\r\\n])[a-z0-9][a-z0-9._:@/-]{0,159}$"},
    "hash": {"type": "string", "pattern": "^(?![\\s\\S]*[\\r\\n])sha256:[0-9a-f]{64}$"},
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "content_hash", "evidence_hash"],
      "properties": {
        "artifact_id": {"$ref": "#/$defs/id"},
        "content_hash": {"$ref": "#/$defs/hash"},
        "evidence_hash": {"$ref": "#/$defs/hash"}
      }
    }
  }
}
